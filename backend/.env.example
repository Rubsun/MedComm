# Docker Compose (recommended): docker compose up -d
DATABASE_URL=postgresql+asyncpg://medcomm:medcomm@localhost:5432/medcomm
TEST_DATABASE_URL=postgresql+asyncpg://medcomm:medcomm@localhost:5432/medcomm_test

# Or local PostgreSQL — adjust credentials accordingly
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/medcomm
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/medcomm_test

SECRET_KEY=change-this-to-a-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
MEDIA_DIR=media
COOKIE_SECURE=false
CORS_ORIGINS=["http://localhost:5173"]
